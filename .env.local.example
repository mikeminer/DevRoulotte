# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_ACCESS_TOKEN=replace-with-long-random-admin-token
FREE_DAILY_MATCH_LIMIT=20
FREE_CALL_LIMIT_SECONDS=300
PREMIUM_CALL_LIMIT_SECONDS=3600
NEXT_COOLDOWN_SECONDS=8
AUTO_SHADOWBAN_REPORT_THRESHOLD=3
MATCH_QUEUE_STALE_SECONDS=45
CRON_SECRET=replace-with-long-random-cron-secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-or-secret-key
# Optional setup-only value used by scripts/configure-supabase.ps1 to apply schema.sql.
# Never expose this in the browser and do not add it to Vercel runtime envs.
SUPABASE_DB_URL=postgresql://postgres.your-project:your-db-password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# Cloudflare Realtime TURN
# Runtime values used by /api/ice. Generate them with scripts/configure-cloudflare-turn.ps1.
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_API_TOKEN=
# Setup-only values for scripts/configure-cloudflare-turn.ps1. Do not add them to client code.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# PayPal Subscriptions
# Use sandbox while developing. scripts/configure-paypal.ps1 can create
# the product, 3.99 EUR/month plan, 5-day free trial, and webhook.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-rest-app-client-id
PAYPAL_CLIENT_SECRET=your-paypal-rest-app-secret
PAYPAL_PLAN_ID=P-xxxxxxxxxxxxxxxxx
PAYPAL_WEBHOOK_ID=WH-xxxxxxxxxxxxxxxxx
PAYPAL_RETURN_URL=http://localhost:3000/profile?paypal=approved
PAYPAL_CANCEL_URL=http://localhost:3000/?paypal=cancelled
