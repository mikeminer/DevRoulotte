# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_ACCESS_TOKEN=replace-with-long-random-admin-token
# Server-only secret used to sign HttpOnly guest sessions. Use at least 32 random bytes.
GUEST_SESSION_SECRET=replace-with-64-random-hex-characters
GUEST_DAILY_MATCH_LIMIT=3
REGISTERED_DAILY_MATCH_LIMIT=15
GUEST_CALL_LIMIT_SECONDS=120
REGISTERED_CALL_LIMIT_SECONDS=300
PREMIUM_TIER_CALL_LIMIT_SECONDS=900
PREMIUM_MONTHLY_PRICE_EUR=3.99
NEXT_COOLDOWN_SECONDS=8
AUTO_SHADOWBAN_REPORT_THRESHOLD=3
MATCH_QUEUE_STALE_SECONDS=45
MATCH_QUEUE_ACTIVE_SECONDS=6
CRON_SECRET=replace-with-long-random-cron-secret
MAINTENANCE_MODE=false
# Optional Google Analytics 4 Measurement ID. GA is loaded only after Analytics consent.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Optional server-only GA4 Measurement Protocol secret for PayPal revenue events.
# Create it in GA4 Admin > Data streams > Measurement Protocol API secrets.
GA4_API_SECRET=
# Optional. region1 keeps collection on Google's EU regional endpoint.
GA4_MEASUREMENT_PROTOCOL_ENDPOINT=https://region1.google-analytics.com/mp/collect
# Optional server-only GA4 Data API config for realtime active-user counters.
# GA4_PROPERTY_ID is the numeric property ID, not the G- measurement ID.
GA4_PROPERTY_ID=
# Recommended on Vercel: base64-encode the full service account JSON key.
GA4_SERVICE_ACCOUNT_JSON_BASE64=
# Alternative to GA4_SERVICE_ACCOUNT_JSON_BASE64:
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=
# Optional server-only PostHog Revenue bridge for verified PayPal webhook revenue.
# Use the Project API key/token from PostHog. Pick the host that matches your region:
# https://eu.i.posthog.com for EU Cloud, https://us.i.posthog.com for US Cloud.
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_REVENUE_EVENT_NAME=purchase_completed

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-or-secret-key
# Optional setup-only value used by scripts/configure-supabase.ps1 to apply schema.sql.
# Never expose this in the browser and do not add it to Vercel runtime envs.
SUPABASE_DB_URL=postgresql://postgres.your-project:your-db-password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
# Optional setup-only value used by scripts/configure-supabase-email-templates.ps1.
# Keep it only in your shell or local .env; never commit a real token.
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=your-project-ref

# Cloudflare Realtime TURN
# Runtime values used by /api/ice. Generate them with scripts/configure-cloudflare-turn.ps1.
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_API_TOKEN=
# Setup-only values for scripts/configure-cloudflare-turn.ps1. Do not add them to client code.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# PayPal Subscriptions
# Use sandbox while developing. scripts/configure-paypal.ps1 can create
# the product, 3.99 EUR/month plan without free trial, and webhook.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-rest-app-client-id
PAYPAL_CLIENT_SECRET=your-paypal-rest-app-secret
PAYPAL_PLAN_ID=P-xxxxxxxxxxxxxxxxx
PAYPAL_WEBHOOK_ID=WH-xxxxxxxxxxxxxxxxx
PAYPAL_RETURN_URL=http://localhost:3000/profile?paypal=approved
PAYPAL_CANCEL_URL=http://localhost:3000/?paypal=cancelled
